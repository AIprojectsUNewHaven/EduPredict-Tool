# EduPredict Pro - Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.

# Required in production — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret-key

# Required in production — sets the initial admin account password
EDUPREDICT_ADMIN_PASSWORD=change-me-strong-password

# Optional — Flask environment (development|production)
FLASK_ENV=production

# Optional — override geo data directory if separate from data/raw
# EDUPREDICT_GEO_DATA_DIR=/path/to/geo

# Optional — S3 bucket for SQLite backups (leave blank to disable)
# S3_BACKUP_BUCKET=your-s3-bucket-name
